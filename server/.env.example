# NayePankh Volunteer System — Server Environment Variables
# Copy this file to .env and fill in your own values

PORT=5000

# MongoDB Atlas connection string
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/nayepankh_volunteers?retryWrites=true&w=majority

# JWT secret — use a long random string
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here

JWT_EXPIRE=7d

NODE_ENV=development

# Frontend URL (change for production)
CLIENT_URL=http://localhost:5173
